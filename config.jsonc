{
  // Valid values: "remote" or "local"
  "dictionaryProvider": "remote",

  // Valid values: any model supporting tool calling available through Ollama
  "model": "qwen2.5:3b",

  // Set to false to disable RAG (skips building/loading the vector DB)
  "ragEnabled": false,

  // RAG settings for book search
  "ragEmbedModel": "nomic-embed-text",
  "ragChunkSize": 500,
  "ragChunkOverlap": 50,
  "ragTopK": 3,
  "ragDbPath": "data/chroma_db",
  "ragCollectionName": "spanish_books"
}
